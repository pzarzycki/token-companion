---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  actionsUrl,
  featureCards,
  latestTag,
  platformCards,
  repoUrl,
  releaseVersion,
  siteDescription,
  sourceRows,
  walkthrough,
} from "../data/site";
import { withBase } from "../lib/paths";

const compatibility = ["Claude CLI", "Claude Desktop", "VS Code", "Codex CLI"];
const heroProof = ["Open source", "Local files", "Inspectable rules"];
---

<BaseLayout description={siteDescription}>
  <section class="hero">
    <div class="container hero-grid hero-grid-dense">
      <div class="hero-copy">
        <p class="eyebrow">Open-source local usage inspector</p>
        <h1>Token Companion</h1>
        <p class="hero-subhead">
          Open-source desktop app for inspecting Claude and Codex token cost from local session records.
        </p>
        <p class="hero-lead">See model cost, session attribution, and drilldown details from files already on your machine.</p>
        <p class="hero-lead hero-lead-secondary">No account, no upload, no closed calculator.</p>
        <div class="button-row">
          <a class="button button-primary" href={withBase("/install/")}>Install</a>
          <a class="button button-secondary button-source" href={repoUrl}>View on GitHub</a>
        </div>
        <ul class="hero-proof-row">
          {heroProof.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <div class="hero-media">
        <div class="product-frame">
          <img
            src={withBase("/scr-sessions.jpg")}
            alt="Token Companion sessions screen"
            width="1162"
            height="700"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="compat-strip">
    <div class="container compat-row">
      <p>Works with</p>
      <ul class="pill-list">
        {compatibility.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section id="features" class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">What it does</p>
        <h2>It keeps the accounting path visible.</h2>
        <p>
          The app stays intentionally narrow: read local records, apply known prices, and preserve enough context to
          check where every number came from.
        </p>
      </div>

      <div class="feature-grid">
        {featureCards.map((feature) => (
          <article class="feature-card">
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="walkthrough" class="section section-alt">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Views</p>
        <h2>Follow the total back to the session.</h2>
        <p>
          These screens cover the normal audit path: start with session attribution, open the drilldown, then inspect
          model totals and pricing corrections.
        </p>
      </div>

      <div class="walkthrough-stack">
        {walkthrough.map((item) => (
          <article class="walkthrough">
            <div class="walkthrough-copy">
              <p class="eyebrow">{item.eyebrow}</p>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
              <ul class="detail-list">
                {item.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
            <div class="walkthrough-media">
              <div class="product-frame">
                <img src={withBase(item.image)} alt={item.alt} width="1162" height="700" />
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="sources" class="section">
    <div class="container sources-layout">
      <div>
        <div class="section-heading section-heading-compact">
          <p class="eyebrow">What it reads</p>
          <h2>Focused on local records.</h2>
          <p>
            If a store exposes token usage, Token Companion counts it. If it does not, the app reports the gap instead
            of inventing a cost.
          </p>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Source</th>
                <th>Location</th>
                <th>Token data</th>
              </tr>
            </thead>
            <tbody>
              {sourceRows.map((row) => (
                <tr>
                  <td>{row.source}</td>
                  <td><code>{row.location}</code></td>
                  <td>{row.tokenData}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <aside class="note-panel">
        <p class="eyebrow">Why totals are defensible</p>
        <h3>Counting rules stay explicit.</h3>
        <p>Parser logic and counting rules are published in the repository.</p>
        <ul class="detail-list">
          <li>Claude usage is counted per assistant message and deduplicated by message id.</li>
          <li>Codex session totals are taken from the last cumulative snapshot in each session file.</li>
          <li>Desktop binary stores remain visible as untracked conversation counts when token usage is unavailable.</li>
        </ul>
        <div class="button-row">
          <a class="button button-ghost" href={repoUrl}>Read the source</a>
          <a class="button button-ghost" href={actionsUrl}>Build status</a>
        </div>
      </aside>
    </div>
  </section>

  <section id="install" class="section section-alt">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Install</p>
        <h2>Open the install page and pick the path that fits your machine.</h2>
        <p>
          The install page keeps the current version, release links, platform tabs, direct downloads, `npx`, and the
          wrapper scripts visible in one place. Current release: <code>{latestTag}</code> ({releaseVersion}).
        </p>
      </div>

      <div class="platform-grid">
        {platformCards.map((platform) => (
          <article class="platform-card">
            <p class="platform-label">{platform.name}</p>
            <h3>{platform.packageType}</h3>
            <p>{platform.note}</p>
            <a class="platform-link" href={withBase(`/install/#${platform.id}`)}>Open {platform.name} instructions</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
      <div class="container cta-band">
        <div>
          <p class="eyebrow">Local records, local calculation</p>
          <h2>Install Token Companion and scan your existing session history.</h2>
        </div>
        <div class="button-row">
          <a class="button button-primary" href={withBase("/install/")}>Install instructions</a>
        </div>
      </div>
    </section>
</BaseLayout>
