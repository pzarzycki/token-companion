---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  actionsUrl,
  featureCards,
  platformCards,
  releasesUrl,
  repoUrl,
  siteDescription,
  sourceRows,
  walkthrough,
} from "../data/site";
import { withBase } from "../lib/paths";

const heroStats = [
  { label: "Sources", value: "Claude + Codex" },
  { label: "Scan mode", value: "Local files" },
  { label: "Rates", value: "Editable" },
];

const compatibility = ["Claude CLI", "Claude Desktop", "VS Code", "Codex CLI"];
---

<BaseLayout description={siteDescription}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Desktop app for local usage records</p>
        <h1>Track token cost from Claude and Codex session files.</h1>
        <p class="hero-lead">
          Token Companion reads the usage records already on your machine, applies an editable price table, and shows
          cost by model, session, and project folder.
        </p>
        <div class="button-row">
          <a class="button button-primary" href={withBase("/install/")}>Install with npx</a>
          <a class="button button-secondary" href={releasesUrl}>Unsigned releases</a>
        </div>
        <ul class="stat-grid">
          {heroStats.map((item) => (
            <li class="stat-card">
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="hero-media">
        <div class="product-frame">
          <img
            src={withBase("/scr-sessions.jpg")}
            alt="Token Companion sessions screen"
            width="1162"
            height="700"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="compat-strip">
    <div class="container compat-row">
      <p>Works with</p>
      <ul class="pill-list">
        {compatibility.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section id="features" class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">What it does</p>
        <h2>It keeps the accounting path visible.</h2>
        <p>
          The app is intentionally narrow: read local records, apply known prices, and keep enough context to check where
          the numbers came from.
        </p>
      </div>

      <div class="feature-grid">
        {featureCards.map((feature) => (
          <article class="feature-card">
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="walkthrough" class="section section-alt">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Views</p>
        <h2>The main views.</h2>
        <p>
          The landing page should show the product, not oversell it. These screens cover the normal path from model
          totals to individual sessions and pricing corrections.
        </p>
      </div>

      <div class="walkthrough-stack">
        {walkthrough.map((item) => (
          <article class="walkthrough">
            <div class="walkthrough-copy">
              <p class="eyebrow">{item.eyebrow}</p>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
              <ul class="detail-list">
                {item.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
            <div class="walkthrough-media">
              <div class="product-frame">
                <img src={withBase(item.image)} alt={item.alt} width="1162" height="700" />
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="sources" class="section">
    <div class="container sources-layout">
      <div>
        <div class="section-heading section-heading-compact">
          <p class="eyebrow">What it reads</p>
          <h2>Focused on local records.</h2>
          <p>
            If a store exposes token usage, Token Companion counts it. If it does not, the app reports the gap instead
            of inventing a cost.
          </p>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Source</th>
                <th>Location</th>
                <th>Token data</th>
              </tr>
            </thead>
            <tbody>
              {sourceRows.map((row) => (
                <tr>
                  <td>{row.source}</td>
                  <td><code>{row.location}</code></td>
                  <td>{row.tokenData}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <aside class="note-panel">
        <p class="eyebrow">Parsing rules</p>
        <h3>Counting rules are explicit.</h3>
        <ul class="detail-list">
          <li>Claude usage is counted per assistant message and deduplicated by message id.</li>
          <li>Codex session totals are taken from the last cumulative snapshot in each session file.</li>
          <li>Desktop binary stores are surfaced as untracked conversation counts when usage is unavailable.</li>
        </ul>
        <div class="button-row">
          <a class="button button-ghost" href={repoUrl}>Read the source</a>
          <a class="button button-ghost" href={actionsUrl}>Build status</a>
        </div>
      </aside>
    </div>
  </section>

  <section id="install" class="section section-alt">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Install</p>
        <h2>Install with npx or use unsigned releases.</h2>
        <p>
          The install notes keep the `npx` source-build path first and leave platform-specific signing and packaging
          details visible instead of hiding them behind a generic download button.
        </p>
      </div>

      <div class="platform-grid">
        {platformCards.map((platform) => (
          <article class="platform-card">
            <p class="platform-label">{platform.name}</p>
            <h3>{platform.packageType}</h3>
            <p>{platform.note}</p>
            <a class="platform-link" href={withBase(`/install/#${platform.id}`)}>Open {platform.name} instructions</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta-band">
      <div>
        <p class="eyebrow">Local records, local calculation</p>
        <h2>Install Token Companion and scan your existing session history.</h2>
      </div>
      <div class="button-row">
        <a class="button button-primary" href={withBase("/install/")}>Install with npx</a>
        <a class="button button-secondary" href={releasesUrl}>Unsigned releases</a>
      </div>
    </div>
  </section>
</BaseLayout>
