---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  checksumUrl,
  latestTag,
  releaseDownloadsBaseUrl,
  releaseVersion,
  releasesUrl,
  repoUrl,
} from "../data/site";

const npxInstall = `npx token-companion@latest`;
const shellScriptUrl = `${repoUrl}/raw/${latestTag}/install.sh`;
const powerShellScriptUrl = `${repoUrl}/raw/${latestTag}/install.ps1`;

const platformInstalls = [
  {
    id: "macos",
    name: "macOS",
    releaseTitle: "Download the unsigned DMG",
    releaseSummary: "Fastest path when you want the current Apple Silicon build directly.",
    primaryDownloadLabel: `Token.Companion-${releaseVersion}-mac-arm64.dmg`,
    primaryDownloadUrl: `${releaseDownloadsBaseUrl}/Token.Companion-${releaseVersion}-mac-arm64.dmg`,
    alternateDownloadLabel: `Token.Companion-${releaseVersion}-mac-arm64.zip`,
    alternateDownloadUrl: `${releaseDownloadsBaseUrl}/Token.Companion-${releaseVersion}-mac-arm64.zip`,
    warningTitle: "Unsigned macOS build",
    warningBody:
      "The app is not notarized. Gatekeeper can block first launch, so open it from Finder with control-click -> Open or allow it in System Settings.",
    npxSummary: "Build the app from the tagged public source on the current Mac.",
    npxRequirements: ["Node.js 24 LTS", "npm / npx", "Xcode Command Line Tools"],
    npxNotes: [
      "Builds on the Mac that will run the app.",
      "Copies Token Companion.app into ~/Applications by default.",
      "Use --install-dir <path> to change the destination.",
    ],
    scriptTitle: "Install via shell script",
    scriptSummary: "Use the checked-in wrapper script instead of invoking the npm bootstrapper directly.",
    scriptCommand: `curl -fsSL ${shellScriptUrl} | sh`,
    scriptNotes: [
      "Calls the same source installer flow as the repo script.",
      "Downloads the tagged source if you run it outside a local clone.",
      "Accepts --version, --dry-run, --package-only, and --install-dir.",
    ],
  },
  {
    id: "windows",
    name: "Windows",
    releaseTitle: "Download the unsigned installer",
    releaseSummary: "Fastest path for the standard per-user Windows install with Start Menu and uninstall support.",
    primaryDownloadLabel: `Token.Companion-${releaseVersion}-win-x64.exe`,
    primaryDownloadUrl: `${releaseDownloadsBaseUrl}/Token.Companion-${releaseVersion}-win-x64.exe`,
    alternateDownloadLabel: null,
    alternateDownloadUrl: null,
    warningTitle: "Unsigned Windows build",
    warningBody:
      "SmartScreen can block the installer. If that happens, choose More info, then Run anyway. That is expected for an unsigned executable.",
    npxSummary: "Build the Windows installer locally from the tagged public source.",
    npxRequirements: ["Node.js 24 LTS", "npm / npx"],
    npxNotes: [
      "Builds a local NSIS installer, then runs it.",
      "The install is per-user and adds a Start Menu entry plus uninstall support.",
      "Use --dry-run first if you want to inspect the build steps.",
    ],
    scriptTitle: "Install via PowerShell script",
    scriptSummary: "Use the checked-in wrapper script instead of invoking the npm bootstrapper directly.",
    scriptCommand: `powershell -ExecutionPolicy Bypass -Command "irm ${powerShellScriptUrl} | iex"`,
    scriptNotes: [
      "Calls the same source installer flow as the repo script.",
      "Downloads the tagged source if you run it outside a local clone.",
      "Accepts -Version, -DryRun, -PackageOnly, and -InstallDir.",
    ],
  },
  {
    id: "linux",
    name: "Linux",
    releaseTitle: "Download the unsigned package",
    releaseSummary: "Fastest path when you want a ready-made package instead of building locally.",
    primaryDownloadLabel: `Token.Companion-${releaseVersion}-linux-amd64.deb`,
    primaryDownloadUrl: `${releaseDownloadsBaseUrl}/Token.Companion-${releaseVersion}-linux-amd64.deb`,
    alternateDownloadLabel: `Token.Companion-${releaseVersion}-linux-x86_64.rpm`,
    alternateDownloadUrl: `${releaseDownloadsBaseUrl}/Token.Companion-${releaseVersion}-linux-x86_64.rpm`,
    warningTitle: "Unsigned Linux packages",
    warningBody:
      "These are convenience artifacts, not signed distro packages. Verify the checksum first and use the package format that matches your system.",
    npxSummary: "Build native packages locally from the tagged public source.",
    npxRequirements: ["Node.js 24 LTS", "npm / npx", "build-essential", "Python 3", "fakeroot", "dpkg", "rpm"],
    npxNotes: [
      "Builds native .deb and .rpm packages on the current machine.",
      "Installs with apt, dnf, or rpm when matching tools are available.",
      "Use --package-only if you only want the package files.",
    ],
    scriptTitle: "Install via shell script",
    scriptSummary: "Use the checked-in wrapper script instead of invoking the npm bootstrapper directly.",
    scriptCommand: `curl -fsSL ${shellScriptUrl} | sh`,
    scriptNotes: [
      "Calls the same source installer flow as the repo script.",
      "Downloads the tagged source if you run it outside a local clone.",
      "Accepts --version, --dry-run, and --package-only.",
    ],
  },
] as const;
---

<BaseLayout
  title="Install"
  description="Install Token Companion from a direct release artifact, the npx bootstrapper, or the checked-in wrapper scripts on macOS, Windows, and Linux."
>
  <section class="section install-page-top">
    <div class="container install-stack">
      <div class="section-heading section-heading-compact install-heading">
        <p class="eyebrow">Install Token Companion</p>
        <h1>Install instructions by platform.</h1>
        <p>
          Pick a platform, then choose direct download, `npx`, or the wrapper script. The current release and the
          exact links stay visible here instead of being hidden behind a separate release page.
        </p>
      </div>

      <section class="install-release-summary" aria-label="Current release">
        <div class="install-release-version">
          <p class="platform-label">Current version</p>
          <div class="release-chip-row">
            <strong>{latestTag}</strong>
            <span>{releaseVersion}</span>
          </div>
        </div>

        <div class="install-release-links">
          <a class="button button-primary" href={releasesUrl}>Release page</a>
          <a class="button button-secondary" href={checksumUrl}>SHA256SUMS</a>
          <a class="button button-secondary" href={shellScriptUrl}>install.sh</a>
          <a class="button button-secondary" href={powerShellScriptUrl}>install.ps1</a>
        </div>

        <div class="install-release-grid">
          <div class="install-release-card">
            <p class="platform-label">Direct downloads</p>
            <ul class="detail-list">
              <li><a href={`${releaseDownloadsBaseUrl}/Token.Companion-${releaseVersion}-mac-arm64.dmg`}>macOS DMG</a></li>
              <li><a href={`${releaseDownloadsBaseUrl}/Token.Companion-${releaseVersion}-win-x64.exe`}>Windows installer</a></li>
              <li><a href={`${releaseDownloadsBaseUrl}/Token.Companion-${releaseVersion}-linux-amd64.deb`}>Linux DEB</a></li>
              <li><a href={`${releaseDownloadsBaseUrl}/Token.Companion-${releaseVersion}-linux-x86_64.rpm`}>Linux RPM</a></li>
            </ul>
          </div>

          <div class="install-release-card">
            <p class="platform-label">Important</p>
            <ul class="detail-list">
              <li>Release artifacts are unsigned.</li>
              <li>`npx` builds locally from the tagged public source.</li>
              <li>The wrapper scripts call the same installer flow without the npm bootstrapper entry point.</li>
            </ul>
          </div>
        </div>
      </section>

      <div class="platform-switcher" data-platform-switcher>
        <div class="platform-tabs" role="tablist" aria-label="Platform selection">
          {platformInstalls.map((platform, index) => (
            <button
              class="platform-tab"
              type="button"
              role="tab"
              id={`tab-${platform.id}`}
              aria-controls={platform.id}
              aria-selected={index === 0 ? "true" : "false"}
              data-platform-tab={platform.id}
            >
              {platform.name}
            </button>
          ))}
        </div>

        <div class="platform-panels">
          {platformInstalls.map((platform, index) => (
            <section
              class="platform-panel"
              id={platform.id}
              role="tabpanel"
              aria-labelledby={`tab-${platform.id}`}
              hidden={index === 0 ? undefined : true}
              data-platform-panel={platform.id}
            >
              <div class="install-choice-grid install-choice-grid-three">
                <article class="install-choice">
                  <p class="platform-label">Option 1</p>
                  <h3>{platform.releaseTitle}</h3>
                  <p>{platform.releaseSummary}</p>
                  <div class="button-row install-card-actions">
                    <a class="button button-primary" href={platform.primaryDownloadUrl}>{platform.primaryDownloadLabel}</a>
                    {platform.alternateDownloadUrl && platform.alternateDownloadLabel ? (
                      <a class="button button-secondary" href={platform.alternateDownloadUrl}>{platform.alternateDownloadLabel}</a>
                    ) : null}
                  </div>
                  <div class="install-warning-block">
                    <p class="install-warning-title">{platform.warningTitle}</p>
                    <p class="install-warning">{platform.warningBody}</p>
                    <p class="install-warning-meta">
                      Verify with <a href={checksumUrl}>SHA256SUMS</a>.
                    </p>
                  </div>
                </article>

                <article class="install-choice">
                  <p class="platform-label">Option 2</p>
                  <h3>Build locally with npx</h3>
                  <p>{platform.npxSummary}</p>
                  <pre class="code-block"><code>{npxInstall}</code></pre>

                  <div class="install-subsection">
                    <p class="command-label">Requirements</p>
                    <ul class="detail-list">
                      {platform.npxRequirements.map((requirement) => (
                        <li>{requirement}</li>
                      ))}
                    </ul>
                  </div>

                  <div class="install-subsection">
                    <p class="command-label">Useful flags</p>
                    <div class="command-stack install-command-stack">
                      <div>
                        <p class="command-label">Dry run</p>
                        <pre class="code-block"><code>{`npx token-companion@latest --dry-run`}</code></pre>
                      </div>
                      <div>
                        <p class="command-label">Build a tag</p>
                        <pre class="code-block"><code>{`npx token-companion@latest --version ${latestTag}`}</code></pre>
                      </div>
                    </div>
                  </div>

                  <div class="install-subsection">
                    <p class="command-label">What it does</p>
                    <ul class="detail-list">
                      {platform.npxNotes.map((note) => (
                        <li>{note}</li>
                      ))}
                    </ul>
                  </div>
                </article>

                <article class="install-choice">
                  <p class="platform-label">Option 3</p>
                  <h3>{platform.scriptTitle}</h3>
                  <p>{platform.scriptSummary}</p>
                  <pre class="code-block"><code>{platform.scriptCommand}</code></pre>

                  <div class="install-subsection">
                    <p class="command-label">What it does</p>
                    <ul class="detail-list">
                      {platform.scriptNotes.map((note) => (
                        <li>{note}</li>
                      ))}
                    </ul>
                  </div>

                  <div class="install-subsection">
                    <p class="command-label">Script source</p>
                    <div class="button-row install-card-actions">
                      {platform.id === "windows" ? (
                        <a class="button button-secondary" href={powerShellScriptUrl}>Open install.ps1</a>
                      ) : (
                        <a class="button button-secondary" href={shellScriptUrl}>Open install.sh</a>
                      )}
                    </div>
                  </div>
                </article>
              </div>
            </section>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const detectPlatform = () => {
      const value = `${navigator.userAgent} ${navigator.platform}`.toLowerCase();

      if (value.includes("win")) return "windows";
      if (value.includes("mac")) return "macos";
      if (value.includes("linux") || value.includes("x11")) return "linux";
      return "macos";
    };

    const switcher = document.querySelector("[data-platform-switcher]");
    if (switcher) {
      const tabs = Array.from(switcher.querySelectorAll("[data-platform-tab]"));
      const panels = Array.from(switcher.querySelectorAll("[data-platform-panel]"));

      const activate = (platform, shouldUpdateHash = true) => {
        tabs.forEach((tab) => {
          const selected = tab.dataset.platformTab === platform;
          tab.setAttribute("aria-selected", String(selected));
          tab.classList.toggle("is-active", selected);
        });

        panels.forEach((panel) => {
          panel.hidden = panel.dataset.platformPanel !== platform;
        });

        if (shouldUpdateHash && window.location.hash !== `#${platform}`) {
          history.replaceState(null, "", `#${platform}`);
        }
      };

      const hashPlatform = window.location.hash.slice(1);
      const detectedPlatform = detectPlatform();
      const initialPlatform = tabs.some((tab) => tab.dataset.platformTab === hashPlatform)
        ? hashPlatform
        : tabs.some((tab) => tab.dataset.platformTab === detectedPlatform)
          ? detectedPlatform
          : "macos";
      activate(initialPlatform, Boolean(hashPlatform));

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          if (tab.dataset.platformTab) activate(tab.dataset.platformTab);
        });
      });
    }
  </script>
</BaseLayout>
