---
import BaseLayout from "../layouts/BaseLayout.astro";
import { releasesUrl, repoUrl } from "../data/site";

const npxInstall = `npx token-companion@latest`;
const releaseHref = `${releasesUrl}`;

const platformInstalls = [
  {
    id: "macos",
    name: "macOS",
    releaseLabel: "Latest macOS release",
    releaseArtifact: "DMG or ZIP from the latest GitHub release",
    releaseWarning:
      "Unsigned macOS builds are not notarized. Gatekeeper will warn on first launch and may require opening the app from System Settings or Finder context menu.",
    npxCommand: npxInstall,
    requirements: ["Node.js 24 LTS", "npm / npx", "Xcode Command Line Tools"],
    npxNotes: [
      "Builds on the Mac that will run the app.",
      "Installs Token Companion.app under ~/Applications by default.",
      "Use --install-dir <path> to choose another destination.",
    ],
  },
  {
    id: "windows",
    name: "Windows",
    releaseLabel: "Latest Windows release",
    releaseArtifact: "NSIS .exe installer from the latest GitHub release",
    releaseWarning:
      "Unsigned Windows builds can trigger SmartScreen. You may need to choose More info and Run anyway before the installer starts.",
    npxCommand: npxInstall,
    requirements: ["Node.js 24 LTS", "npm / npx"],
    npxNotes: [
      "Builds a local NSIS installer, then runs it.",
      "The install is per-user and adds a Start Menu entry plus uninstall support.",
      "Use --dry-run first if you want to inspect the exact build steps.",
    ],
  },
  {
    id: "linux",
    name: "Linux",
    releaseLabel: "Latest Linux release",
    releaseArtifact: ".deb or .rpm package from the latest GitHub release",
    releaseWarning:
      "Linux packages are unsigned convenience artifacts. Install them only if the package type matches your distro and you are comfortable verifying the release contents yourself.",
    npxCommand: npxInstall,
    requirements: ["Node.js 24 LTS", "npm / npx", "build-essential", "Python 3", "fakeroot", "dpkg", "rpm"],
    npxNotes: [
      "Builds native .deb and .rpm packages on the current machine.",
      "Installs with apt, dnf, or rpm when the matching tools are available.",
      "Use --package-only if you only want the built package files.",
    ],
  },
] as const;

const installFaq = [
  {
    question: "Why keep npx as an option if release binaries exist?",
    answer:
      "The npx path builds from public source on your own machine. The release download is faster, but it is still an unsigned convenience artifact.",
  },
  {
    question: "What does the installer package actually do?",
    answer:
      "It fetches the matching GitHub source, runs the normal build steps locally, then launches the platform installer or package output from that local build.",
  },
  {
    question: "Can I pin a specific version?",
    answer:
      "Yes. Run npx token-companion@latest --version <tag> when you want to build a specific tagged release instead of the default latest path.",
  },
] as const;
---

<BaseLayout title="Install" description="Install Token Companion from the latest unsigned release or build it locally with npx on macOS, Windows, and Linux.">
  <section class="hero install-hero">
    <div class="container hero-grid hero-grid-wide">
      <div class="hero-copy install-copy">
        <p class="eyebrow">Install Token Companion</p>
        <h1>Pick your platform, then choose release or local build.</h1>
        <p class="hero-lead">
          Token Companion keeps the install path explicit. You can download the latest unsigned release for your
          platform or run <code>npx</code> and build the app locally from source.
        </p>
        <div class="button-row">
          <a class="button button-primary" href={releaseHref}>Open latest release</a>
          <a class="button button-secondary" href="#install-options">Build with npx</a>
        </div>
      </div>

      <aside class="note-panel install-summary">
        <p class="eyebrow">Recommended flow</p>
        <h3>One platform at a time.</h3>
        <ul class="detail-list">
          <li>The page defaults to the current browser platform and can be switched manually.</li>
          <li>Release downloads are convenient, but every platform build is unsigned.</li>
          <li>The npx path keeps the build on your own machine and shows original errors if something breaks.</li>
        </ul>
      </aside>
    </div>
  </section>

  <section id="install-options" class="section section-alt">
    <div class="container">
      <div class="section-heading section-heading-compact">
        <p class="eyebrow">Installation</p>
        <h2>Two install paths for the selected platform.</h2>
        <p>
          Use the latest release when you want the quickest path. Use <code>npx</code> when you want the build to run
          locally from public source.
        </p>
      </div>

      <div class="platform-switcher" data-platform-switcher>
        <div class="platform-tabs" role="tablist" aria-label="Platform selection">
          {platformInstalls.map((platform, index) => (
            <button
              class="platform-tab"
              type="button"
              role="tab"
              id={`tab-${platform.id}`}
              aria-controls={`panel-${platform.id}`}
              aria-selected={index === 0 ? "true" : "false"}
              data-platform-tab={platform.id}
            >
              {platform.name}
            </button>
          ))}
        </div>

        <div class="platform-panels">
          {platformInstalls.map((platform, index) => (
            <section
              class="platform-panel"
              id={`panel-${platform.id}`}
              role="tabpanel"
              aria-labelledby={`tab-${platform.id}`}
              hidden={index === 0 ? undefined : true}
              data-platform-panel={platform.id}
            >
              <div class="install-choice-grid">
                <article class="install-choice">
                  <p class="platform-label">Option 1</p>
                  <h3>{platform.releaseLabel}</h3>
                  <p>{platform.releaseArtifact}</p>
                  <p class="install-warning">{platform.releaseWarning}</p>
                  <div class="button-row">
                    <a class="button button-primary" href={releaseHref}>Open latest release</a>
                  </div>
                </article>

                <article class="install-choice">
                  <p class="platform-label">Option 2</p>
                  <h3>Build locally with npx</h3>
                  <pre class="code-block"><code>{platform.npxCommand}</code></pre>
                  <ul class="detail-list">
                    {platform.npxNotes.map((note) => (
                      <li>{note}</li>
                    ))}
                  </ul>
                </article>
              </div>

              <div class="install-detail-grid">
                <article class="note-panel">
                  <p class="eyebrow">Requirements</p>
                  <h3>{platform.name}</h3>
                  <ul class="detail-list">
                    {platform.requirements.map((requirement) => (
                      <li>{requirement}</li>
                    ))}
                  </ul>
                </article>

                <article class="note-panel">
                  <p class="eyebrow">Useful flags</p>
                  <h3>Inspect or pin the build</h3>
                  <div class="command-stack install-command-stack">
                    <div>
                      <p class="command-label">Dry run</p>
                      <pre class="code-block"><code>{`npx token-companion@latest --dry-run`}</code></pre>
                    </div>
                    <div>
                      <p class="command-label">Build a tag</p>
                      <pre class="code-block"><code>{`npx token-companion@latest --version v0.1.3`}</code></pre>
                    </div>
                  </div>
                </article>
              </div>
            </section>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="first-launch" class="section">
    <div class="container sources-layout">
      <div>
        <div class="section-heading section-heading-compact">
          <p class="eyebrow">First launch</p>
          <h2>The app should start scanning immediately.</h2>
          <p>
            The Dashboard is the first screen. Scanning is read-only and standard Claude and Codex locations are
            detected without extra configuration.
          </p>
        </div>
        <ul class="detail-list">
          <li>Claude sessions are read from <code>~/.claude/projects</code>.</li>
          <li>Codex sessions are read from <code>~/.codex/sessions</code>.</li>
          <li>Desktop stores without token usage are shown as untracked conversations instead of estimated costs.</li>
        </ul>
      </div>

      <aside class="note-panel">
        <p class="eyebrow">No account</p>
        <h3>Everything stays local.</h3>
        <p>
          Token Companion reads files already on your machine. It does not require an account, telemetry setup, or a
          hosted service.
        </p>
      </aside>
    </div>
  </section>

  <section id="manual-build" class="section section-alt">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Manual build</p>
        <h2>Use the same commands yourself.</h2>
      </div>

      <div class="command-stack build-commands">
        <div>
          <p class="command-label">Clone and install</p>
          <pre class="code-block"><code>{`git clone ${repoUrl}.git
cd token-companion
npm ci`}</code></pre>
        </div>
        <div>
          <p class="command-label">Build distributables</p>
          <pre class="code-block"><code>{`npm run typecheck
npm run dist`}</code></pre>
        </div>
      </div>
    </div>
  </section>

  <section id="install-faq" class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2>Installer behavior in plain terms.</h2>
      </div>

      <div class="detail-grid">
        {installFaq.map((item) => (
          <article class="note-panel">
            <p class="eyebrow">Question</p>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    const detectPlatform = () => {
      const value = `${navigator.userAgent} ${navigator.platform}`.toLowerCase();

      if (value.includes("win")) return "windows";
      if (value.includes("mac")) return "macos";
      if (value.includes("linux") || value.includes("x11")) return "linux";
      return "macos";
    };

    const switcher = document.querySelector("[data-platform-switcher]");
    if (switcher) {
      const tabs = Array.from(switcher.querySelectorAll("[data-platform-tab]"));
      const panels = Array.from(switcher.querySelectorAll("[data-platform-panel]"));

      const activate = (platform) => {
        tabs.forEach((tab) => {
          const selected = tab.dataset.platformTab === platform;
          tab.setAttribute("aria-selected", String(selected));
          tab.classList.toggle("is-active", selected);
        });

        panels.forEach((panel) => {
          panel.hidden = panel.dataset.platformPanel !== platform;
        });
      };

      const initialPlatform = tabs.some((tab) => tab.dataset.platformTab === detectPlatform()) ? detectPlatform() : "macos";
      activate(initialPlatform);

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          if (tab.dataset.platformTab) activate(tab.dataset.platformTab);
        });
      });
    }
  </script>
</BaseLayout>
