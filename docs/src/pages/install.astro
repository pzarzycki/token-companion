---
import BaseLayout from "../layouts/BaseLayout.astro";
import { repoUrl } from "../data/site";

const npxInstall = `npx token-companion@latest`;
const releaseVersion = "0.1.4";
const latestTag = `v${releaseVersion}`;
const checksumUrl = `${repoUrl}/releases/download/${latestTag}/SHA256SUMS`;

const platformInstalls = [
  {
    id: "macos",
    name: "macOS",
    releaseTitle: "Download the unsigned DMG",
    releaseSummary: "Best for Apple Silicon Macs when you want the shortest path to install.",
    primaryDownloadLabel: "Download macOS DMG",
    primaryDownloadUrl: `${repoUrl}/releases/download/${latestTag}/Token.Companion-${releaseVersion}-mac-arm64.dmg`,
    alternateDownloadLabel: "ZIP build",
    alternateDownloadUrl: `${repoUrl}/releases/download/${latestTag}/Token.Companion-${releaseVersion}-mac-arm64.zip`,
    warningTitle: "Unsigned macOS build",
    warningBody:
      "The app is not notarized. Gatekeeper will warn on first launch. If macOS blocks it, open Finder, control-click the app, choose Open, then confirm in the dialog or System Settings.",
    npxTitle: "Build locally with npx",
    npxSummary: "Best when you want the app built from public source on your own machine.",
    requirements: ["Node.js 24 LTS", "npm / npx", "Xcode Command Line Tools"],
    notes: [
      "Builds on the Mac that will run the app.",
      "Installs Token Companion.app under ~/Applications by default.",
      "Use --install-dir <path> to choose another destination.",
    ],
  },
  {
    id: "windows",
    name: "Windows",
    releaseTitle: "Download the unsigned installer",
    releaseSummary: "Best for the standard per-user Windows install with Start Menu and uninstall support.",
    primaryDownloadLabel: "Download Windows installer",
    primaryDownloadUrl: `${repoUrl}/releases/download/${latestTag}/Token.Companion-${releaseVersion}-win-x64.exe`,
    alternateDownloadLabel: null,
    alternateDownloadUrl: null,
    warningTitle: "Unsigned Windows build",
    warningBody:
      "SmartScreen may block the installer. If that happens, choose More info, then Run anyway. This is expected because the binary is not signed with a Microsoft-trusted certificate.",
    npxTitle: "Build locally with npx",
    npxSummary: "Best when you want to avoid downloading a prebuilt executable and prefer a local build.",
    requirements: ["Node.js 24 LTS", "npm / npx"],
    notes: [
      "Builds a local NSIS installer, then runs it.",
      "The install is per-user and adds a Start Menu entry plus uninstall support.",
      "Use --dry-run first if you want to inspect the exact build steps.",
    ],
  },
  {
    id: "linux",
    name: "Linux",
    releaseTitle: "Download the unsigned package",
    releaseSummary: "Best when you want a ready-made package instead of running the build locally.",
    primaryDownloadLabel: "Download Linux DEB",
    primaryDownloadUrl: `${repoUrl}/releases/download/${latestTag}/Token.Companion-${releaseVersion}-linux-amd64.deb`,
    alternateDownloadLabel: "RPM build",
    alternateDownloadUrl: `${repoUrl}/releases/download/${latestTag}/Token.Companion-${releaseVersion}-linux-x86_64.rpm`,
    warningTitle: "Unsigned Linux packages",
    warningBody:
      "These packages are convenience artifacts, not signed distro packages. Verify the checksum before installing and use the package format that matches your distribution.",
    npxTitle: "Build locally with npx",
    npxSummary: "Best when you want the package produced on the current machine and installed with local tooling.",
    requirements: ["Node.js 24 LTS", "npm / npx", "build-essential", "Python 3", "fakeroot", "dpkg", "rpm"],
    notes: [
      "Builds native .deb and .rpm packages on the current machine.",
      "Installs with apt, dnf, or rpm when the matching tools are available.",
      "Use --package-only if you only want the built package files.",
    ],
  },
] as const;
---

<BaseLayout title="Install" description="Install Token Companion from a direct platform download or build it locally with npx on macOS, Windows, and Linux.">
  <section class="hero install-hero">
    <div class="container hero-grid hero-grid-wide">
      <div class="hero-copy install-copy">
        <p class="eyebrow">Install Token Companion</p>
        <h1>Pick your platform, then choose direct download or local build.</h1>
        <p class="hero-lead">
          Every platform has two paths. You can download the current release artifact directly, or you can run
          <code>npx</code> and build from public source on your own machine.
        </p>
      </div>

      <aside class="note-panel install-summary">
        <p class="eyebrow">Important</p>
        <h3>Prebuilt downloads are unsigned.</h3>
        <ul class="detail-list">
          <li>The direct download path is faster, but each artifact can trigger OS trust warnings.</li>
          <li>The <code>npx</code> path keeps the build local and prints original build errors when something fails.</li>
          <li>Checksums for {latestTag} are published with the release.</li>
        </ul>
      </aside>
    </div>
  </section>

  <section id="install-options" class="section section-alt">
    <div class="container">
      <div class="section-heading section-heading-compact">
        <p class="eyebrow">Installation</p>
        <h2>Exactly two options for the selected platform.</h2>
        <p>Select a platform. The page defaults to the current browser platform, and each tab shows one direct-download card plus one local-build card.</p>
      </div>

      <div class="platform-switcher" data-platform-switcher>
        <div class="platform-tabs" role="tablist" aria-label="Platform selection">
          {platformInstalls.map((platform, index) => (
            <button
              class="platform-tab"
              type="button"
              role="tab"
              id={`tab-${platform.id}`}
              aria-controls={`panel-${platform.id}`}
              aria-selected={index === 0 ? "true" : "false"}
              data-platform-tab={platform.id}
            >
              {platform.name}
            </button>
          ))}
        </div>

        <div class="platform-panels">
          {platformInstalls.map((platform, index) => (
            <section
              class="platform-panel"
              id={`panel-${platform.id}`}
              role="tabpanel"
              aria-labelledby={`tab-${platform.id}`}
              hidden={index === 0 ? undefined : true}
              data-platform-panel={platform.id}
            >
              <div class="install-choice-grid">
                <article class="install-choice">
                  <p class="platform-label">Option 1</p>
                  <h3>{platform.releaseTitle}</h3>
                  <p>{platform.releaseSummary}</p>
                  <div class="button-row install-card-actions">
                    <a class="button button-primary" href={platform.primaryDownloadUrl}>{platform.primaryDownloadLabel}</a>
                    {platform.alternateDownloadUrl && platform.alternateDownloadLabel ? (
                      <a class="button button-secondary" href={platform.alternateDownloadUrl}>{platform.alternateDownloadLabel}</a>
                    ) : null}
                  </div>
                  <div class="install-warning-block">
                    <p class="install-warning-title">{platform.warningTitle}</p>
                    <p class="install-warning">{platform.warningBody}</p>
                    <p class="install-warning-meta">
                      Verify with <a href={checksumUrl}>SHA256SUMS</a>.
                    </p>
                  </div>
                </article>

                <article class="install-choice">
                  <p class="platform-label">Option 2</p>
                  <h3>{platform.npxTitle}</h3>
                  <p>{platform.npxSummary}</p>
                  <pre class="code-block"><code>{platform.id === "windows" ? `npx token-companion@latest` : npxInstall}</code></pre>

                  <div class="install-subsection">
                    <p class="command-label">Requirements</p>
                    <ul class="detail-list">
                      {platform.requirements.map((requirement) => (
                        <li>{requirement}</li>
                      ))}
                    </ul>
                  </div>

                  <div class="install-subsection">
                    <p class="command-label">What it does</p>
                    <ul class="detail-list">
                      {platform.notes.map((note) => (
                        <li>{note}</li>
                      ))}
                    </ul>
                  </div>

                  <div class="install-subsection">
                    <p class="command-label">Useful flags</p>
                    <div class="command-stack install-command-stack">
                      <div>
                        <p class="command-label">Dry run</p>
                        <pre class="code-block"><code>{`npx token-companion@latest --dry-run`}</code></pre>
                      </div>
                      <div>
                        <p class="command-label">Build a tag</p>
                        <pre class="code-block"><code>{`npx token-companion@latest --version ${latestTag}`}</code></pre>
                      </div>
                    </div>
                  </div>
                </article>
              </div>
            </section>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="manual-build" class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Manual build</p>
        <h2>Use the same commands yourself.</h2>
      </div>

      <div class="command-stack build-commands">
        <div>
          <p class="command-label">Clone and install</p>
          <pre class="code-block"><code>{`git clone ${repoUrl}.git
cd token-companion
npm ci`}</code></pre>
        </div>
        <div>
          <p class="command-label">Build distributables</p>
          <pre class="code-block"><code>{`npm run typecheck
npm run dist`}</code></pre>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const detectPlatform = () => {
      const value = `${navigator.userAgent} ${navigator.platform}`.toLowerCase();

      if (value.includes("win")) return "windows";
      if (value.includes("mac")) return "macos";
      if (value.includes("linux") || value.includes("x11")) return "linux";
      return "macos";
    };

    const switcher = document.querySelector("[data-platform-switcher]");
    if (switcher) {
      const tabs = Array.from(switcher.querySelectorAll("[data-platform-tab]"));
      const panels = Array.from(switcher.querySelectorAll("[data-platform-panel]"));

      const activate = (platform) => {
        tabs.forEach((tab) => {
          const selected = tab.dataset.platformTab === platform;
          tab.setAttribute("aria-selected", String(selected));
          tab.classList.toggle("is-active", selected);
        });

        panels.forEach((panel) => {
          panel.hidden = panel.dataset.platformPanel !== platform;
        });
      };

      const detectedPlatform = detectPlatform();
      const initialPlatform = tabs.some((tab) => tab.dataset.platformTab === detectedPlatform) ? detectedPlatform : "macos";
      activate(initialPlatform);

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          if (tab.dataset.platformTab) activate(tab.dataset.platformTab);
        });
      });
    }
  </script>
</BaseLayout>
