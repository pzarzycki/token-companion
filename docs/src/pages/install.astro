---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildWorkflowUrl, releasesUrl, repoUrl } from "../data/site";

const platforms = [
  {
    id: "macos",
    name: "macOS",
    packageType: ".dmg",
    requirements: ["macOS 12 Monterey or later"],
    steps: [
      "Download the latest disk image from GitHub Releases.",
      "Open the .dmg and drag Token Companion into Applications.",
      "Eject the disk image after the copy finishes.",
    ],
    noteTitle: "First launch on macOS",
    noteBody:
      "The app is not signed with an Apple Developer certificate, so Gatekeeper blocks the first open. Use Finder's Open action once, or clear the quarantine flag from Terminal.",
    commandBlocks: [
      {
        title: "Terminal fallback",
        lang: "bash",
        lines: ["xattr -cr /Applications/Token\\ Companion.app"],
      },
    ],
    verify:
      "Launch the app from Applications. The Dashboard should appear and the header should show scanning activity within a second or two.",
  },
  {
    id: "windows",
    name: "Windows",
    packageType: "Setup.exe",
    requirements: ["Windows 10 64-bit or later"],
    steps: [
      "Download the latest Setup.exe from GitHub Releases.",
      "Run the Squirrel installer.",
      "If SmartScreen appears, click More info and then Run anyway.",
      "Launch Token Companion from the Start Menu after setup completes.",
    ],
    noteTitle: "First launch on Windows",
    noteBody:
      "Unsigned Windows installers trigger SmartScreen until they build reputation. That warning is expected for a small open-source desktop tool distributed directly through GitHub Releases.",
    commandBlocks: [],
    verify:
      "On first launch the app should begin scanning %USERPROFILE%\\.claude\\projects and %USERPROFILE%\\.codex\\sessions automatically.",
  },
  {
    id: "linux",
    name: "Linux",
    packageType: ".deb / .rpm",
    requirements: [
      "x86-64 Linux",
      "A Debian-based distro for .deb packages or an RPM-based distro for .rpm packages",
    ],
    steps: [
      "Download the package that matches your distro from GitHub Releases.",
      "Install it with your package manager.",
      "Launch Token Companion from the application launcher after installation.",
    ],
    noteTitle: "Package notes on Linux",
    noteBody:
      "Packages may be unsigned depending on how they were built and distributed. If a release for your distro is not published yet, build from source on the target machine.",
    commandBlocks: [
      {
        title: "Debian or Ubuntu",
        lang: "bash",
        lines: ["sudo apt install ./token-companion_<version>_amd64.deb"],
      },
      {
        title: "Fedora or RHEL",
        lang: "bash",
        lines: ["sudo dnf install ./token-companion-<version>.x86_64.rpm"],
      },
    ],
    verify:
      "After launch, the Dashboard should appear and scanning should begin without any extra configuration for standard Claude and Codex installs.",
  },
];

const buildCards = [
  {
    title: "Shared prerequisites",
    items: [
      "Node.js 24 LTS",
      "npm",
      "A native build toolchain for classic-level on the host platform",
    ],
  },
  {
    title: "Platform-specific toolchains",
    items: [
      "macOS: Xcode Command Line Tools",
      "Windows: Visual Studio Build Tools with Desktop development with C++",
      "Linux: build-essential, Python 3, fakeroot, and rpm",
    ],
  },
  {
    title: "Why builds are local to the host OS",
    items: [
      "classic-level is a native module",
      "Electron packaging is platform-specific",
      "The release job builds each platform on its matching runner",
    ],
  },
];
---

<BaseLayout title="Install" description="Install Token Companion on macOS, Windows, and Linux.">
  <section class="hero install-hero">
    <div class="container install-hero-grid">
      <div class="hero-copy install-copy">
        <p class="eyebrow">Install Token Companion</p>
        <h1>Download it, clear the first-run warning once, and start scanning.</h1>
        <p class="hero-lead">
          Token Companion is distributed through GitHub Releases as an unsigned desktop app. The install path is short
          on every platform, but the first-run warning should be explicit and easy to follow.
        </p>
        <div class="button-row">
          <a class="button button-primary" href={releasesUrl}>Open releases</a>
          <a class="button button-secondary" href={buildWorkflowUrl}>Build workflow</a>
        </div>
        <div class="jump-links">
          {platforms.map((platform) => (
            <a href={`#${platform.id}`}>{platform.name}</a>
          ))}
        </div>
      </div>

      <aside class="note-panel install-summary">
        <p class="eyebrow">Release formats</p>
        <h3>One download path per desktop OS.</h3>
        <ul class="detail-list">
          <li>macOS ships as a <code>.dmg</code> with a one-time Gatekeeper step.</li>
          <li>Windows ships as <code>Setup.exe</code> through Squirrel with the usual SmartScreen prompt.</li>
          <li>Linux uses native <code>.deb</code> and <code>.rpm</code> packages when a release is published.</li>
        </ul>
      </aside>
    </div>
  </section>

  {platforms.map((platform, index) => (
    <section id={platform.id} class:list={["section", index % 2 === 1 && "section-alt"]}>
      <div class="container install-layout">
        <div class="install-main">
          <p class="eyebrow">{platform.name}</p>
          <h2>{platform.packageType}</h2>
          <ul class="detail-list">
            {platform.requirements.map((requirement) => (
              <li>{requirement}</li>
            ))}
          </ul>

          <h3>Install</h3>
          <ol class="step-list">
            {platform.steps.map((step) => (
              <li>{step}</li>
            ))}
          </ol>

          {platform.commandBlocks.length > 0 && (
            <div class="command-stack">
              {platform.commandBlocks.map((block) => (
                <div>
                  <p class="command-label">{block.title}</p>
                  <pre class="code-block"><code>{block.lines.join("\n")}</code></pre>
                </div>
              ))}
            </div>
          )}
        </div>

        <aside class="note-panel install-aside">
          <p class="eyebrow">{platform.noteTitle}</p>
          <h3>{platform.name}</h3>
          <p>{platform.noteBody}</p>
          <p class="install-verify"><strong>After launch:</strong> {platform.verify}</p>
        </aside>
      </div>
    </section>
  ))}

  <section id="first-launch" class="section">
    <div class="container sources-layout">
      <div>
        <div class="section-heading section-heading-compact">
          <p class="eyebrow">First launch</p>
          <h2>What you should see immediately.</h2>
          <p>
            The Dashboard is the first screen. Scanning begins automatically and stays read-only. Standard installs are
            detected without extra configuration.
          </p>
        </div>
        <ul class="detail-list">
          <li>The header should show scanning activity almost immediately.</li>
          <li>Claude sessions are read from <code>~/.claude/projects</code>.</li>
          <li>Codex sessions are read from <code>~/.codex/sessions</code>.</li>
          <li>If desktop chat stores are present but uncountable, they appear as untracked conversations instead of fake token totals.</li>
        </ul>
      </div>

      <aside class="note-panel">
        <p class="eyebrow">If a release is missing</p>
        <h3>Build from source on the target OS.</h3>
        <p>
          The app bundles a native dependency, so packaging should happen on the same operating system that will consume
          the build. The repository already includes per-platform build scripts and a matching GitHub Actions matrix.
        </p>
        <div class="button-row">
          <a class="button button-ghost" href={repoUrl}>Clone repository</a>
          <a class="button button-ghost" href={buildWorkflowUrl}>Inspect CI build</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Build from source</p>
        <h2>Use the host platform, install dependencies once, then run the matching build target.</h2>
      </div>

      <div class="feature-grid build-grid">
        {buildCards.map((card) => (
          <article class="feature-card">
            <h3>{card.title}</h3>
            <ul class="detail-list">
              {card.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <div class="command-stack build-commands">
        <div>
          <p class="command-label">Clone and install</p>
          <pre class="code-block"><code>{`git clone ${repoUrl}.git
cd token-companion
npm install`}</code></pre>
        </div>
        <div>
          <p class="command-label">Build on the current OS</p>
          <pre class="code-block"><code>{`npm run package
npm run make`}</code></pre>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
