---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildWorkflowUrl, releasesUrl, repoUrl } from "../data/site";

const npxInstall = `npx token-companion`;
const posixInstall = `curl -fsSL https://raw.githubusercontent.com/pzarzycki/token-companion/main/install.sh | sh`;
const windowsInstall = `irm https://raw.githubusercontent.com/pzarzycki/token-companion/main/install.ps1 | iex`;

const sourceSteps = [
  "Downloads the selected source tag or branch into a local build cache.",
  "Runs npm ci, typecheck, and the platform electron-builder packaging command.",
  "Installs the locally built app or package for the current operating system.",
  "Prints original command output when something fails.",
];

const platformBuilds = [
  {
    id: "macos",
    name: "macOS",
    target: "~/Applications/Token Companion.app by default",
    requirements: ["Node.js 24 LTS and npm", "Xcode Command Line Tools"],
    notes: [
      "Builds on the Mac that will run the app.",
      "Use --install-dir to choose a different application folder.",
      "No Apple Developer certificate or notarization is used.",
    ],
  },
  {
    id: "windows",
    name: "Windows",
    target: "Per-user NSIS install by default",
    requirements: ["Node.js 24 LTS and npm"],
    notes: [
      "Builds a local NSIS installer and runs it.",
      "The install is per-user, shows up in Start Menu, and creates an uninstall entry.",
      "Unsigned Windows binaries can still trigger SmartScreen.",
    ],
  },
  {
    id: "linux",
    name: "Linux",
    target: ".deb or .rpm package",
    requirements: ["Node.js 24 LTS and npm", "build-essential", "Python 3", "fakeroot", "dpkg", "rpm"],
    notes: [
      "Builds native Debian/Ubuntu and Fedora/RHEL style packages.",
      "Installs with apt, dnf, or rpm when possible.",
      "Use --package-only if you only want the package file under out/dist.",
    ],
  },
];

const releaseArtifacts = [
  {
    platform: "macOS",
    artifact: ".dmg / .zip",
    warning: "Unsigned macOS artifacts. Gatekeeper first-launch warning is expected.",
  },
  {
    platform: "Windows",
    artifact: "NSIS .exe installer",
    warning: "Unsigned NSIS installer. SmartScreen warning is expected.",
  },
  {
    platform: "Linux",
    artifact: ".deb / .rpm",
    warning: "Native packages for common Debian/RPM distributions when a release is published.",
  },
];

const installFaq = [
  {
    question: "Why does npmjs.com show npm i token-companion?",
    answer:
      "That install box is generic npm package-page UI. Token Companion is meant to be run with npx so the installer package can execute.",
  },
  {
    question: "Does npx token-companion contain the app source?",
    answer:
      "No. The npm package is a small bootstrapper. It downloads the matching GitHub source tag, then builds the Electron app locally on your machine.",
  },
  {
    question: "Will rerunning npx token-companion update an older install?",
    answer:
      "It rebuilds and reruns the platform installer. If npm resolves a newer installer package and the local build succeeds, the newer app install replaces the older one. Use npx token-companion@latest when you want the newest installer package immediately.",
  },
];
---

<BaseLayout title="Install" description="Build and install Token Companion locally from source on macOS, Windows, and Linux.">
  <section class="hero install-hero">
    <div class="container install-hero-grid">
      <div class="hero-copy install-copy">
        <p class="eyebrow">Install Token Companion</p>
        <h1>Install with npx, then let it build locally.</h1>
        <p class="hero-lead">
          Token Companion is open source and does not use paid developer signatures. The primary install path uses
          <code>npx</code> to build from source on your computer; unsigned GitHub release binaries remain available as a convenience.
        </p>
        <div class="button-row">
          <a class="button button-primary" href="#source-build">Install with npx</a>
          <a class="button button-secondary" href={releasesUrl}>Unsigned releases</a>
        </div>
        <div class="jump-links">
          {platformBuilds.map((platform) => (
            <a href={`#${platform.id}`}>{platform.name}</a>
          ))}
          <a href="#release-binaries">Binaries</a>
        </div>
      </div>

      <aside class="note-panel install-summary">
        <p class="eyebrow">Default path</p>
        <h3>One command, local build.</h3>
        <ul class="detail-list">
          <li>Use <code>npx</code> on macOS, Windows, or Linux.</li>
          <li><code>npm</code> and <code>npx</code> come with the standard Node.js install.</li>
          <li>Install Node.js from <code>nodejs.org/en/download</code> if <code>npx</code> is missing.</li>
          <li>Pin a tag with <code>--version</code>.</li>
          <li>Use dry-run mode to inspect the planned commands first.</li>
        </ul>
      </aside>
    </div>
  </section>

  <section id="source-build" class="section section-alt">
    <div class="container sources-layout">
      <div>
        <div class="section-heading section-heading-compact">
          <p class="eyebrow">Source build</p>
          <h2>Recommended install command.</h2>
          <p>
            The `npx` installer fetches the public source, builds the Electron app on the current machine, and installs
            the artifact produced by that build.
          </p>
        </div>

        <div class="command-stack">
          <div>
            <p class="command-label">macOS, Windows, or Linux</p>
            <pre class="code-block"><code>{npxInstall}</code></pre>
          </div>
          <div>
            <p class="command-label">If npx is missing</p>
            <pre class="code-block"><code>{`Install Node.js from https://nodejs.org/en/download`}</code></pre>
          </div>
        </div>
      </div>

      <aside class="note-panel">
        <p class="eyebrow">What it does</p>
        <h3>No hidden packaging service.</h3>
        <ol class="step-list">
          {sourceSteps.map((step) => (
            <li>{step}</li>
          ))}
        </ol>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Inspect and pin</p>
        <h2>Review the installer or build a specific tag.</h2>
      </div>

      <div class="command-stack build-commands">
        <div>
          <p class="command-label">Default install</p>
          <pre class="code-block"><code>{npxInstall}</code></pre>
        </div>
        <div>
          <p class="command-label">Dry run</p>
          <pre class="code-block"><code>{`npx token-companion --dry-run`}</code></pre>
        </div>
        <div>
          <p class="command-label">Build a tag</p>
          <pre class="code-block"><code>{`npx token-companion --version v0.1.3`}</code></pre>
        </div>
        <div>
          <p class="command-label">Fallback scripts</p>
          <pre class="code-block"><code>{`${posixInstall}
${windowsInstall}`}</code></pre>
        </div>
      </div>

      <ul class="detail-list install-option-list">
        <li><code>--dry-run</code> prints checks, commands, and targets without building.</li>
        <li><code>--package-only</code> builds packages without installing them.</li>
        <li><code>--install-dir &lt;path&gt;</code> changes the macOS app destination. Windows one-click NSIS install does not support it.</li>
      </ul>
    </div>
  </section>

  {platformBuilds.map((platform, index) => (
    <section id={platform.id} class:list={["section", index % 2 === 0 && "section-alt"]}>
      <div class="container install-layout">
        <div class="install-main">
          <p class="eyebrow">{platform.name}</p>
          <h2>{platform.target}</h2>
          <h3>Prerequisites</h3>
          <ul class="detail-list">
            {platform.requirements.map((requirement) => (
              <li>{requirement}</li>
            ))}
          </ul>
        </div>

        <aside class="note-panel install-aside">
          <p class="eyebrow">Platform notes</p>
          <h3>{platform.name}</h3>
          <ul class="detail-list">
            {platform.notes.map((note) => (
              <li>{note}</li>
            ))}
          </ul>
        </aside>
      </div>
    </section>
  ))}

  <section id="first-launch" class="section section-alt">
    <div class="container sources-layout">
      <div>
        <div class="section-heading section-heading-compact">
          <p class="eyebrow">First launch</p>
          <h2>The app should start scanning immediately.</h2>
          <p>
            The Dashboard is the first screen. Scanning is read-only and standard Claude and Codex locations are detected
            without extra configuration.
          </p>
        </div>
        <ul class="detail-list">
          <li>Claude sessions are read from <code>~/.claude/projects</code>.</li>
          <li>Codex sessions are read from <code>~/.codex/sessions</code>.</li>
          <li>Desktop stores without token usage are shown as untracked conversations instead of estimated costs.</li>
        </ul>
      </div>

      <aside class="note-panel">
        <p class="eyebrow">No account</p>
        <h3>Everything stays local.</h3>
        <p>
          Token Companion reads files already on your machine. It does not require an account, telemetry setup, or a
          hosted service.
        </p>
      </aside>
    </div>
  </section>

  <section id="release-binaries" class="section">
    <div class="container sources-layout">
      <div>
        <div class="section-heading section-heading-compact">
          <p class="eyebrow">Optional binaries</p>
          <h2>Unsigned release artifacts stay available.</h2>
          <p>
            Releases are tagged from <code>main</code> and built on matching GitHub Actions runners. They are convenient,
            but they are not signed with Apple or Microsoft developer certificates. Tagged releases include
            <code>SHA256SUMS</code> for the uploaded artifacts.
          </p>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Platform</th>
                <th>Artifact</th>
                <th>Warning</th>
              </tr>
            </thead>
            <tbody>
              {releaseArtifacts.map((artifact) => (
                <tr>
                  <td>{artifact.platform}</td>
                  <td><code>{artifact.artifact}</code></td>
                  <td>{artifact.warning}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <aside class="note-panel">
        <p class="eyebrow">Release path</p>
        <h3>Use binaries when convenience matters more than local provenance.</h3>
        <p>
          The source installer is the preferred trust path. Release binaries are still useful for quick installs,
          testing, or users who do not want a local build toolchain.
        </p>
        <div class="button-row">
          <a class="button button-ghost" href={releasesUrl}>Open releases</a>
          <a class="button button-ghost" href={buildWorkflowUrl}>Build workflow</a>
        </div>
      </aside>
    </div>
  </section>

  <section id="manual-build" class="section section-alt">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Manual build</p>
        <h2>Use the same commands yourself.</h2>
      </div>

      <div class="command-stack build-commands">
        <div>
          <p class="command-label">Clone and install</p>
          <pre class="code-block"><code>{`git clone ${repoUrl}.git
cd token-companion
npm ci`}</code></pre>
        </div>
        <div>
          <p class="command-label">Build distributables</p>
          <pre class="code-block"><code>{`npm run typecheck
npm run dist`}</code></pre>
        </div>
      </div>
    </div>
  </section>

  <section id="install-faq" class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2>Installer behavior in plain terms.</h2>
      </div>

      <div class="detail-grid">
        {installFaq.map((item) => (
          <article class="note-panel">
            <p class="eyebrow">Question</p>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
